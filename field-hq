<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="Field HQ">
  <title>Field HQ</title>
  <style>
    :root {
      --bg:       #F2F1EE;
      --card:     #FFFFFF;
      --text:     #111827;
      --muted:    #6B7280;
      --accent:   #1E40AF;
      --accent-bg:#EFF6FF;
      --warn:     #B91C1C;
      --warn-bg:  #FEF2F2;
      --ok:       #065F46;
      --ok-bg:    #ECFDF5;
      --border:   #E5E7EB;
      --r:        14px;
      --font:     -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: var(--font);
      background: var(--bg);
      color: var(--text);
      font-size: 18px;
      min-height: 100vh;
    }

    /* ‚îÄ‚îÄ Header ‚îÄ‚îÄ */
    #hdr {
      background: var(--accent);
      color: #fff;
      padding: 14px 20px;
      padding-top: calc(14px + env(safe-area-inset-top));
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      position: sticky;
      top: 0;
      z-index: 10;
    }
    #hdrDate { font-size: 17px; font-weight: 600; opacity: .88; }
    #hdrTime { font-size: 32px; font-weight: 700; letter-spacing: -.5px; }

    /* ‚îÄ‚îÄ Grid ‚îÄ‚îÄ */
    .grid {
      padding: 14px;
      display: grid;
      gap: 14px;
      max-width: 860px;
      margin: 0 auto;
    }
    @media (min-width: 600px) {
      .grid { grid-template-columns: 1fr 1fr; }
      .wx-card { grid-column: 1 / -1; }
    }

    /* ‚îÄ‚îÄ Card ‚îÄ‚îÄ */
    .card {
      background: var(--card);
      border-radius: var(--r);
      box-shadow: 0 1px 4px rgba(0,0,0,.09);
      overflow: hidden;
    }
    .card-head {
      padding: 13px 16px 11px;
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .card-label {
      font-size: 12px;
      font-weight: 800;
      letter-spacing: .09em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .card-body { padding: 12px 16px 4px; }

    .btn-add {
      background: var(--accent-bg);
      color: var(--accent);
      border: none;
      padding: 6px 14px;
      border-radius: 20px;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
    }
    .btn-add:active { opacity: .65; }

    /* ‚îÄ‚îÄ Weather ‚îÄ‚îÄ */
    .wx-main {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 16px 8px;
    }
    .wx-icon { font-size: 56px; line-height: 1; }
    .wx-temp { font-size: 60px; font-weight: 700; letter-spacing: -3px; line-height: 1; }
    .wx-desc { font-size: 17px; color: var(--muted); margin-top: 4px; }
    .wx-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      padding: 4px 16px 16px;
    }
    .wx-cell {
      background: var(--bg);
      border-radius: 10px;
      padding: 9px 4px;
      text-align: center;
    }
    .wx-lbl {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .06em;
      color: var(--muted);
    }
    .wx-val {
      font-size: 18px;
      font-weight: 700;
      margin-top: 3px;
    }

    /* ‚îÄ‚îÄ Schedule ‚îÄ‚îÄ */
    .ev-item {
      display: flex;
      gap: 12px;
      padding: 10px 0;
      border-bottom: 1px solid var(--border);
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
    }
    .ev-item:last-child { border-bottom: none; padding-bottom: 12px; }
    .ev-time {
      font-size: 14px;
      font-weight: 700;
      color: var(--muted);
      min-width: 60px;
      padding-top: 2px;
      flex-shrink: 0;
    }
    .ev-body { flex: 1; min-width: 0; }
    .ev-title { font-size: 19px; font-weight: 500; }
    .ev-meta { font-size: 13px; color: var(--muted); margin-top: 2px; }
    .ev-tag {
      display: inline-block;
      font-size: 12px;
      background: var(--accent-bg);
      color: var(--accent);
      padding: 2px 8px;
      border-radius: 10px;
      margin-top: 3px;
    }
    .ev-item.past { opacity: .4; }
    .ev-item.now {
      background: var(--accent-bg);
      border-radius: 10px;
      margin: 2px -10px;
      padding: 10px 10px;
      border-bottom: none;
    }

    /* ‚îÄ‚îÄ Projects ‚îÄ‚îÄ */
    .pr-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 0;
      border-bottom: 1px solid var(--border);
    }
    .pr-item:last-child { border-bottom: none; padding-bottom: 12px; }
    .pr-info { flex: 1; cursor: pointer; min-width: 0; }
    .pr-name { font-size: 19px; font-weight: 600; }
    .pr-days { font-size: 14px; margin-top: 2px; }
    .pr-days.warn { color: var(--warn); font-weight: 700; }
    .pr-days.ok   { color: var(--muted); }
    .btn-done {
      background: var(--ok-bg);
      color: var(--ok);
      border: none;
      border-radius: 10px;
      padding: 9px 13px;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      flex-shrink: 0;
      -webkit-tap-highlight-color: transparent;
    }
    .btn-done:active { opacity: .7; }

    /* ‚îÄ‚îÄ Todos ‚îÄ‚îÄ */
    .td-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 0;
      border-bottom: 1px solid var(--border);
    }
    .td-item:last-child { border-bottom: none; padding-bottom: 12px; }
    .td-circle {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      border: 2.5px solid var(--border);
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      font-size: 14px;
      font-weight: 700;
      -webkit-tap-highlight-color: transparent;
    }
    .td-circle.done { background: var(--ok); border-color: var(--ok); color: #fff; }
    .td-text { font-size: 19px; flex: 1; cursor: pointer; min-width: 0; -webkit-tap-highlight-color: transparent; }
    .td-text.done { text-decoration: line-through; color: var(--muted); }
    .td-carry {
      font-size: 11px;
      color: var(--muted);
      background: var(--bg);
      padding: 2px 7px;
      border-radius: 8px;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .td-del {
      color: var(--muted);
      background: none;
      border: none;
      font-size: 22px;
      line-height: 1;
      padding: 0 2px;
      cursor: pointer;
      flex-shrink: 0;
      -webkit-tap-highlight-color: transparent;
    }
    .td-del:active { color: var(--warn); }

    /* ‚îÄ‚îÄ Empty state ‚îÄ‚îÄ */
    .empty {
      color: var(--muted);
      font-size: 16px;
      text-align: center;
      padding: 20px 0 16px;
    }

    /* ‚îÄ‚îÄ Bottom sheet modal ‚îÄ‚îÄ */
    .overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,.48);
      z-index: 100;
      display: flex;
      align-items: flex-end;
      justify-content: center;
    }
    .sheet {
      background: var(--card);
      border-radius: 20px 20px 0 0;
      padding: 12px 20px;
      padding-bottom: calc(24px + env(safe-area-inset-bottom));
      width: 100%;
      max-width: 600px;
      animation: up .18s ease-out;
    }
    @keyframes up {
      from { transform: translateY(48px); opacity: 0; }
      to   { transform: translateY(0);    opacity: 1; }
    }
    .sheet-handle {
      width: 40px; height: 4px;
      background: var(--border);
      border-radius: 2px;
      margin: 0 auto 18px;
    }
    .sheet-title { font-size: 22px; font-weight: 800; margin-bottom: 18px; }

    .fld { margin-bottom: 14px; }
    .fld label {
      display: block;
      font-size: 12px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: .07em;
      color: var(--muted);
      margin-bottom: 6px;
    }
    .fld input, .fld select {
      width: 100%;
      padding: 13px 14px;
      border: 2px solid var(--border);
      border-radius: 11px;
      font-size: 18px;
      font-family: var(--font);
      background: var(--bg);
      color: var(--text);
      outline: none;
      -webkit-appearance: none;
    }
    .fld input:focus, .fld select:focus { border-color: var(--accent); }
    .fld-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

    .btn-primary {
      width: 100%;
      padding: 15px;
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: 12px;
      font-size: 19px;
      font-weight: 700;
      cursor: pointer;
      margin-top: 6px;
      -webkit-tap-highlight-color: transparent;
    }
    .btn-primary:active { opacity: .82; }
    .btn-danger {
      width: 100%;
      padding: 13px;
      background: var(--warn-bg);
      color: var(--warn);
      border: none;
      border-radius: 12px;
      font-size: 17px;
      font-weight: 600;
      cursor: pointer;
      margin-top: 10px;
      -webkit-tap-highlight-color: transparent;
    }
    .btn-danger:active { opacity: .8; }
  </style>
</head>
<body>

<div id="hdr">
  <div id="hdrDate"></div>
  <div id="hdrTime"></div>
</div>

<div class="grid">

  <!-- Weather -->
  <div class="card wx-card">
    <div class="card-head">
      <span class="card-label">Whitehall, MT</span>
      <button class="btn-add" onclick="refreshWeather()">‚Üª Refresh</button>
    </div>
    <div id="wxOut"><div style="padding:28px;text-align:center;color:var(--muted)">Loading weather‚Ä¶</div></div>
  </div>

  <!-- Schedule -->
  <div class="card">
    <div class="card-head">
      <span class="card-label">Schedule</span>
      <button class="btn-add" onclick="openModal('addEv')">+ Add</button>
    </div>
    <div class="card-body" id="evOut"></div>
  </div>

  <!-- Projects -->
  <div class="card">
    <div class="card-head">
      <span class="card-label">Projects</span>
      <button class="btn-add" onclick="openModal('addPr')">+ Add</button>
    </div>
    <div class="card-body" id="prOut"></div>
  </div>

  <!-- Todos -->
  <div class="card">
    <div class="card-head">
      <span class="card-label">Today's Tasks</span>
      <button class="btn-add" onclick="openModal('addTd')">+ Add</button>
    </div>
    <div class="card-body" id="tdOut"></div>
  </div>

</div>

<!-- Modal overlay -->
<div class="overlay" id="overlay" style="display:none" onclick="bgClose(event)">
  <div class="sheet">
    <div class="sheet-handle"></div>
    <div id="sheetBody"></div>
  </div>
</div>

<script>
'use strict';

// ‚îÄ‚îÄ Storage ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
const _get = k => { try { return JSON.parse(localStorage.getItem(k)); } catch { return null; } };
const _set = (k, v) => localStorage.setItem(k, JSON.stringify(v));

let evs  = _get('fhq_ev') ?? [];
let pros = _get('fhq_pr') ?? [];
let tds  = _get('fhq_td') ?? [];
let wxC  = _get('fhq_wx') ?? null;

// ‚îÄ‚îÄ Tiny helpers ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
const uid     = () => Date.now().toString(36) + Math.random().toString(36).slice(2,7);
const today   = () => new Date().toISOString().slice(0,10);
const esc     = s => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');

function fmt12(t) {           // "14:30" ‚Üí "2:30 PM"
  const [h,m] = t.split(':').map(Number);
  return `${h%12||12}:${String(m).padStart(2,'0')} ${h>=12?'PM':'AM'}`;
}
function sunTime(iso) {       // "2026-05-04T05:47" ‚Üí "5:47 AM"
  const [h,m] = iso.split('T')[1].split(':').map(Number);
  return `${h%12||12}:${String(m).padStart(2,'0')} ${h>=12?'PM':'AM'}`;
}
function daysAgo(d) {
  return Math.floor((new Date(today()) - new Date(d)) / 86400000);
}

// ‚îÄ‚îÄ Clock ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
function tick() {
  const n = new Date();
  document.getElementById('hdrTime').textContent =
    n.toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit'});
  document.getElementById('hdrDate').textContent =
    n.toLocaleDateString('en-US',{weekday:'long',month:'short',day:'numeric'});
}
setInterval(tick, 1000);
tick();

// ‚îÄ‚îÄ Weather ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
const WMO = {
  0:['‚òÄÔ∏è','Clear'],
  1:['üå§','Mainly Clear'], 2:['‚õÖ','Partly Cloudy'], 3:['‚òÅÔ∏è','Overcast'],
  45:['üå´','Fog'], 48:['üå´','Icy Fog'],
  51:['üå¶','Lt Drizzle'], 53:['üå¶','Drizzle'], 55:['üåß','Hvy Drizzle'],
  61:['üåß','Lt Rain'],    63:['üåß','Rain'],     65:['üåß','Hvy Rain'],
  71:['üå®','Lt Snow'],    73:['üå®','Snow'],     75:['‚ùÑÔ∏è','Hvy Snow'], 77:['‚ùÑÔ∏è','Snow Grains'],
  80:['üå¶','Lt Showers'], 81:['üåß','Showers'],  82:['‚õà','Hvy Showers'],
  85:['üå®','Snow Showers'],86:['‚ùÑÔ∏è','Hvy Snow Showers'],
  95:['‚õà','Thunderstorm'],96:['‚õà','Hail'],     99:['‚õà','Hvy Hail'],
};

function drawWeather(d) {
  const c = d.current, dy = d.daily;
  const [icon,desc] = WMO[c.weathercode] ?? ['üå°Ô∏è','‚Äî'];
  document.getElementById('wxOut').innerHTML = `
    <div class="wx-main">
      <div class="wx-icon">${icon}</div>
      <div>
        <div class="wx-temp">${Math.round(c.temperature_2m)}¬∞</div>
        <div class="wx-desc">${desc} ¬∑ Feels ${Math.round(c.apparent_temperature)}¬∞</div>
      </div>
    </div>
    <div class="wx-grid">
      <div class="wx-cell">
        <div class="wx-lbl">High / Low</div>
        <div class="wx-val">${Math.round(dy.temperature_2m_max[0])}¬∞ / ${Math.round(dy.temperature_2m_min[0])}¬∞</div>
      </div>
      <div class="wx-cell">
        <div class="wx-lbl">Wind</div>
        <div class="wx-val">${Math.round(c.windspeed_10m)} mph</div>
      </div>
      <div class="wx-cell">
        <div class="wx-lbl">Rain %</div>
        <div class="wx-val">${dy.precipitation_probability_max[0]}%</div>
      </div>
      <div class="wx-cell">
        <div class="wx-lbl">Sunrise</div>
        <div class="wx-val" style="font-size:15px">${sunTime(dy.sunrise[0])}</div>
      </div>
      <div class="wx-cell">
        <div class="wx-lbl">Sunset</div>
        <div class="wx-val" style="font-size:15px">${sunTime(dy.sunset[0])}</div>
      </div>
      <div class="wx-cell">
        <div class="wx-lbl">Updated</div>
        <div class="wx-val" style="font-size:13px;color:var(--muted)">${new Date().toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit'})}</div>
      </div>
    </div>`;
}

async function refreshWeather() {
  document.getElementById('wxOut').innerHTML =
    '<div style="padding:28px;text-align:center;color:var(--muted)">Updating‚Ä¶</div>';
  try {
    const url =
      'https://api.open-meteo.com/v1/forecast'
      + '?latitude=45.8683&longitude=-112.0927'
      + '&current=temperature_2m,weathercode,windspeed_10m,apparent_temperature'
      + '&daily=temperature_2m_max,temperature_2m_min,precipitation_probability_max,sunrise,sunset'
      + '&temperature_unit=fahrenheit&windspeed_unit=mph'
      + '&timezone=America%2FDenver&forecast_days=1';
    const data = await fetch(url).then(r => { if (!r.ok) throw 0; return r.json(); });
    wxC = { data, ts: Date.now() };
    _set('fhq_wx', wxC);
    drawWeather(data);
  } catch {
    if (wxC?.data) drawWeather(wxC.data);
    else document.getElementById('wxOut').innerHTML =
      '<div style="padding:28px;text-align:center;color:var(--muted)">Weather unavailable ‚Äî check connection</div>';
  }
}

function loadWeather() {
  if (wxC?.ts && Date.now() - wxC.ts < 30*60*1000 && wxC.data) drawWeather(wxC.data);
  else refreshWeather();
}
setInterval(refreshWeather, 30*60*1000);

// ‚îÄ‚îÄ Schedule ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
function drawSchedule() {
  const t = today();
  const now = new Date();
  const nowM = now.getHours()*60 + now.getMinutes();
  const list = evs.filter(e => e.date===t).sort((a,b)=>a.time.localeCompare(b.time));
  const el = document.getElementById('evOut');
  if (!list.length) {
    el.innerHTML = '<div class="empty">No events today<br>Tap + Add to plan your day</div>';
    return;
  }
  el.innerHTML = list.map(e => {
    const [h,m] = e.time.split(':').map(Number);
    const sm = h*60+m, em = sm+(e.duration||60);
    const past = em < nowM, cur = sm<=nowM && nowM<em;
    const pr = e.pid ? pros.find(p=>p.id===e.pid) : null;
    const dur = e.duration && e.duration!==60
      ? (e.duration<60 ? `${e.duration} min` : `${e.duration/60} hr`) : '';
    return `
      <div class="ev-item${past?' past':''}${cur?' now':''}" onclick="openModal('editEv','${e.id}')">
        <div class="ev-time">${fmt12(e.time)}</div>
        <div class="ev-body">
          <div class="ev-title">${esc(e.title)}</div>
          ${dur||pr ? `<div class="ev-meta">${dur}${dur&&pr?' ¬∑ ':''}${pr?`<span class="ev-tag">üìå ${esc(pr.name)}</span>`:''}</div>` : ''}
        </div>
      </div>`;
  }).join('');
}

// ‚îÄ‚îÄ Projects ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
function drawProjects() {
  const active = pros.filter(p=>p.status==='active');
  const el = document.getElementById('prOut');
  if (!active.length) {
    el.innerHTML = '<div class="empty">No active projects<br>Tap + Add to start tracking</div>';
    return;
  }
  el.innerHTML = active.map(p => {
    const days = daysAgo(p.startDate);
    const warn = days >= 2;
    const lbl  = days===0 ? 'Started today' : `Day ${days+1}`;
    return `
      <div class="pr-item">
        <div class="pr-info" onclick="openModal('editPr','${p.id}')">
          <div class="pr-name">${esc(p.name)}</div>
          <div class="pr-days ${warn?'warn':'ok'}">${warn?'‚ö†Ô∏è ':''}${lbl}${warn?' ‚Äî needs wrap-up':''}</div>
        </div>
        <button class="btn-done" onclick="doneProject('${p.id}')">Done ‚úì</button>
      </div>`;
  }).join('');
}

function doneProject(id) {
  const p = pros.find(x=>x.id===id);
  if (!p) return;
  p.status = 'completed'; p.doneDate = today();
  _set('fhq_pr', pros); drawProjects();
}

// ‚îÄ‚îÄ Todos ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
function drawTodos() {
  const t = today();
  // Show: all uncompleted + completed today only
  const vis = tds.filter(x => !x.done || x.doneDate===t);
  const sorted = [...vis].sort((a,b)=>(a.done?1:0)-(b.done?1:0));
  const el = document.getElementById('tdOut');
  if (!vis.length) {
    el.innerHTML = '<div class="empty">All clear!<br>Tap + Add to add tasks</div>';
    return;
  }
  el.innerHTML = sorted.map(x => {
    const carry = !x.done && x.created!==t;
    return `
      <div class="td-item">
        <div class="td-circle${x.done?' done':''}" onclick="toggleTd('${x.id}')">${x.done?'‚úì':''}</div>
        <div class="td-text${x.done?' done':''}" onclick="toggleTd('${x.id}')">${esc(x.text)}</div>
        ${carry?'<span class="td-carry">carried over</span>':''}
        <button class="td-del" onclick="deleteTd('${x.id}')">√ó</button>
      </div>`;
  }).join('');
}

function toggleTd(id) {
  const x = tds.find(t=>t.id===id);
  if (!x) return;
  x.done = !x.done; x.doneDate = x.done ? today() : null;
  _set('fhq_td', tds); drawTodos();
}
function deleteTd(id) {
  tds = tds.filter(x=>x.id!==id);
  _set('fhq_td', tds); drawTodos();
}

// ‚îÄ‚îÄ Modal helpers ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
function timeOpts(sel) {
  let out = '';
  for (let h=5; h<=19; h++) {
    for (let m=0; m<60; m+=30) {
      if (h===5 && m===0) continue;
      if (h===19 && m>0)  break;
      const v = `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}`;
      out += `<option value="${v}"${v===sel?' selected':''}>${fmt12(v)}</option>`;
    }
  }
  return out;
}
function defaultTime() {
  const n=new Date(); let h=n.getHours(), m=n.getMinutes()<30?30:0;
  if(m===0) h++; h=Math.max(5,Math.min(19,h));
  if(h===5) m=30; if(h===19) m=0;
  return `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}`;
}
const DURS = [{v:30,l:'30 min'},{v:60,l:'1 hr'},{v:90,l:'1.5 hr'},{v:120,l:'2 hr'},{v:180,l:'3 hr'},{v:240,l:'4 hr'}];
function durOpts(sel) {
  return DURS.map(d=>`<option value="${d.v}"${d.v==sel?' selected':''}>${d.l}</option>`).join('');
}
function projOpts(sel) {
  const ap = pros.filter(p=>p.status==='active');
  if (!ap.length) return '';
  return `<div class="fld"><label>Project (optional)</label>
    <select id="fPid"><option value="">No project</option>
    ${ap.map(p=>`<option value="${p.id}"${p.id===sel?' selected':''}>${esc(p.name)}</option>`).join('')}
    </select></div>`;
}

// ‚îÄ‚îÄ Modal ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
let mType=null, mId=null;

function openModal(type, id) {
  mType=type; mId=id||null;
  const b = document.getElementById('sheetBody');

  if (type==='addEv') {
    const dt=defaultTime();
    b.innerHTML=`
      <div class="sheet-title">Add Event</div>
      <div class="fld"><label>What</label><input id="fEtit" placeholder="Event name" autocomplete="off"></div>
      <div class="fld-row">
        <div class="fld"><label>Time</label><select id="fEtime">${timeOpts(dt)}</select></div>
        <div class="fld"><label>Duration</label><select id="fEdur">${durOpts(60)}</select></div>
      </div>
      ${projOpts('')}
      <button class="btn-primary" onclick="saveEv()">Add to Schedule</button>`;

  } else if (type==='editEv') {
    const e=evs.find(x=>x.id===id); if(!e) return;
    b.innerHTML=`
      <div class="sheet-title">Edit Event</div>
      <div class="fld"><label>What</label><input id="fEtit" value="${esc(e.title)}" autocomplete="off"></div>
      <div class="fld-row">
        <div class="fld"><label>Time</label><select id="fEtime">${timeOpts(e.time)}</select></div>
        <div class="fld"><label>Duration</label><select id="fEdur">${durOpts(e.duration||60)}</select></div>
      </div>
      ${projOpts(e.pid||'')}
      <button class="btn-primary" onclick="saveEv()">Save Changes</button>
      <button class="btn-danger" onclick="deleteEv()">Delete Event</button>`;

  } else if (type==='addPr') {
    b.innerHTML=`
      <div class="sheet-title">New Project</div>
      <div class="fld"><label>Project Name</label><input id="fPname" placeholder="e.g. Fence line repair ‚Äî north pasture" autocomplete="off"></div>
      <button class="btn-primary" onclick="savePr()">Start Tracking</button>`;

  } else if (type==='editPr') {
    const p=pros.find(x=>x.id===id); if(!p) return;
    b.innerHTML=`
      <div class="sheet-title">Edit Project</div>
      <div class="fld"><label>Project Name</label><input id="fPname" value="${esc(p.name)}" autocomplete="off"></div>
      <button class="btn-primary" onclick="savePr()">Save</button>
      <button class="btn-danger" onclick="deletePr()">Delete Project</button>`;

  } else if (type==='addTd') {
    b.innerHTML=`
      <div class="sheet-title">Add Task</div>
      <div class="fld"><label>Task</label><input id="fTtext" placeholder="What needs to get done?" autocomplete="off"></div>
      <button class="btn-primary" onclick="saveTd()">Add Task</button>`;
  }

  document.getElementById('overlay').style.display='flex';
  setTimeout(()=>{ b.querySelector('input')?.focus(); }, 80);
}

function closeModal() {
  document.getElementById('overlay').style.display='none';
  mType=mId=null;
}
function bgClose(e) {
  if (e.target===document.getElementById('overlay')) closeModal();
}

// Saves
function saveEv() {
  const title = document.getElementById('fEtit')?.value.trim(); if(!title) return;
  const time  = document.getElementById('fEtime').value;
  const dur   = +document.getElementById('fEdur').value;
  const pid   = document.getElementById('fPid')?.value || null;
  if (mType==='addEv') {
    evs.push({id:uid(), date:today(), time, title, duration:dur, pid});
  } else {
    const e=evs.find(x=>x.id===mId); if(!e) return;
    Object.assign(e,{title,time,duration:dur,pid});
  }
  _set('fhq_ev',evs); drawSchedule(); closeModal();
}
function deleteEv() {
  evs=evs.filter(x=>x.id!==mId); _set('fhq_ev',evs); drawSchedule(); closeModal();
}

function savePr() {
  const name=document.getElementById('fPname')?.value.trim(); if(!name) return;
  if (mType==='addPr') {
    pros.push({id:uid(), name, startDate:today(), status:'active'});
  } else {
    const p=pros.find(x=>x.id===mId); if(!p) return;
    p.name=name;
  }
  _set('fhq_pr',pros); drawProjects(); closeModal();
}
function deletePr() {
  pros=pros.filter(x=>x.id!==mId); _set('fhq_pr',pros); drawProjects(); closeModal();
}

function saveTd() {
  const text=document.getElementById('fTtext')?.value.trim(); if(!text) return;
  tds.push({id:uid(), text, created:today(), done:false});
  _set('fhq_td',tds); drawTodos(); closeModal();
}

// Keyboard shortcuts
document.addEventListener('keydown', e => {
  if (e.key==='Escape') { closeModal(); return; }
  if (e.key==='Enter' && mType) {
    const map = {addEv:saveEv, editEv:saveEv, addPr:savePr, editPr:savePr, addTd:saveTd};
    map[mType]?.();
  }
});

// ‚îÄ‚îÄ Boot ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
loadWeather();
drawSchedule();
drawProjects();
drawTodos();
setInterval(drawSchedule, 60_000); // re-highlight current event every min
</script>
